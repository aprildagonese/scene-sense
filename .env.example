# DigitalOcean infrastructure (shared)
DIGITAL_OCEAN_MODEL_ACCESS_KEY=your-gradient-api-key
DIGITAL_OCEAN_DATABASE_URL=postgresql://user:password@host:25060/defaultdb?sslmode=require
DIGITAL_OCEAN_GPU_DROPLET_IP=your-gpu-droplet-ip

# LinkedIn OAuth app (shared — users connect their own accounts via Settings)
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# Auth (NextAuth.js + Google OAuth)
NEXTAUTH_SECRET=generate-a-random-32-char-string
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Encryption key for user credentials stored in DB (32 bytes as hex)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIALS_ENCRYPTION_KEY=generate-a-64-char-hex-string

# Optional: LinkedIn profile QR code
MY_LINKEDIN_PROFILE_URL=https://www.linkedin.com/in/yourprofile
